---
import { Avatar } from '@components/common/avatar';
import DockSocialMobile from './DockSocialMobile.tsx';
import { FaGithub, FaSquareXTwitter, FaSteam, FaSpotify, FaBilibili } from 'react-icons/fa6';
import solitudeAvatar from '@assets/avatar.jpg';
import { type Locale, DEFAULT_LOCALE, buildLocalePath } from '@lib/i18n';

interface Props {
    lang?: Locale;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const aboutUrl = buildLocalePath(lang, '/about');
---

<div
    data-dock-social
    class:list={['text-color-ui flex items-center', 'min-h-[4em] 2xl:min-h-[5em]', 'justify-end']}
>
    <!-- 移动端、平板、小桌面：社交链接汉堡菜单（<1536px） -->
    <div data-dock-social-compact class="flex items-center gap-3 sm:gap-4 2xl:hidden">
        <DockSocialMobile client:load />
        <a href={aboutUrl} class="block transition-transform hover:scale-105">
            <Avatar
                className="h-10 w-10 shadow-xl sm:h-12 sm:w-12 md:h-14 md:w-14 lg:h-16 lg:w-16"
                src={solitudeAvatar.src}
                showFallback={true}
                client:visible
            />
        </a>
    </div>

    <!-- 大屏桌面端：完整社交图标展示（≥1536px） -->
    <div data-dock-social-full class="hidden items-center 2xl:flex">
        <div class:list={['flex items-center', '3xl:mr-14 mr-12', '3xl:space-x-12 space-x-10']}>
            <span>
                <a
                    href="https://github.com/SolitudeRA"
                    target="_blank"
                    class="dock-social-inline 3xl:h-11 3xl:w-11 h-10 w-10"
                >
                    <FaGithub className="3xl:h-6 3xl:w-6 h-5 w-5" />
                </a>
            </span>
            <span>
                <a
                    href="https://x.com/SolitudeRA"
                    target="_blank"
                    class="dock-social-inline 3xl:h-11 3xl:w-11 h-10 w-10"
                >
                    <FaSquareXTwitter className="3xl:h-6 3xl:w-6 h-5 w-5" />
                </a>
            </span>
            <span>
                <a
                    href="https://steamcommunity.com/id/SolitudeRA/"
                    target="_blank"
                    class="dock-social-inline 3xl:h-11 3xl:w-11 h-10 w-10"
                >
                    <FaSteam className="3xl:h-6 3xl:w-6 h-5 w-5" />
                </a>
            </span>
            <span>
                <a
                    href="https://open.spotify.com/user/29a85ixn15w4zcbmb0lkix9h3?si=1c70dc8fa5dc418c"
                    target="_blank"
                    class="dock-social-inline 3xl:h-11 3xl:w-11 h-10 w-10"
                >
                    <FaSpotify className="3xl:h-6 3xl:w-6 h-5 w-5" />
                </a>
            </span>
            <span>
                <a
                    href="https://space.bilibili.com/1724972"
                    target="_blank"
                    class="dock-social-inline 3xl:h-11 3xl:w-11 h-10 w-10"
                >
                    <FaBilibili className="3xl:h-6 3xl:w-6 h-5 w-5" />
                </a>
            </span>
        </div>
        <a href={aboutUrl} class="block transition-transform hover:scale-105">
            <Avatar
                className="h-20 w-20 shadow-xl"
                src={solitudeAvatar.src}
                showFallback={true}
                client:visible
            />
        </a>
    </div>
</div>
