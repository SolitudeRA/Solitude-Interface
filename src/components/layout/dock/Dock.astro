---
interface Props {
    isFixed?: boolean;
}

const { isFixed = false } = Astro.props;
---

<div
    data-dock-root
    class:list={[
        'min-h-[8vh] w-full items-center md:min-h-[9vh] lg:min-h-[10vh]',
        'pb-3 md:pb-4',
        'flex justify-between md:grid md:grid-cols-3',
        '3xl:px-16 px-3 sm:px-4 md:px-6 lg:px-8 xl:px-10 2xl:px-12',
        'gap-2 md:gap-3 lg:gap-4',
        isFixed ? 'fixed right-0 bottom-0 left-0 z-50' : '',
    ]}
>
    <slot />
</div>

<script>
    const dockWindow = window as Window & {
        __solitudeDockLayoutGuard?: boolean;
    };

    if (!dockWindow.__solitudeDockLayoutGuard) {
        dockWindow.__solitudeDockLayoutGuard = true;

        const COLLAPSED_CLASS = 'dock--social-collapsed';
        const MEASURING_CLASS = 'dock--measuring-social';
        const FULL_SOCIAL_BREAKPOINT = 1536;
        const COLLAPSE_GAP = 32;
        const EXPAND_GAP = 56;

        let dockLayoutFrame: number | null = null;
        let dockResizeObserver: ResizeObserver | null = null;

        const measureDockRoot = (root: HTMLElement) => {
            const nav = root.querySelector<HTMLElement>('[data-dock-nav]');
            const socialFull = root.querySelector<HTMLElement>('[data-dock-social-full]');

            if (!nav || !socialFull) return;

            if (window.innerWidth < FULL_SOCIAL_BREAKPOINT) {
                root.classList.remove(COLLAPSED_CLASS);
                root.classList.remove(MEASURING_CLASS);
                return;
            }

            const wasCollapsed = root.classList.contains(COLLAPSED_CLASS);

            if (wasCollapsed) {
                root.classList.add(MEASURING_CLASS);
                root.classList.remove(COLLAPSED_CLASS);
            }

            const navRect = nav.getBoundingClientRect();
            const socialRect = socialFull.getBoundingClientRect();
            const safetyGap = socialRect.left - navRect.right;
            const minGap = wasCollapsed ? EXPAND_GAP : COLLAPSE_GAP;

            root.classList.toggle(COLLAPSED_CLASS, safetyGap < minGap);
            root.classList.remove(MEASURING_CLASS);
        };

        const updateDockLayout = () => {
            dockLayoutFrame = null;
            document
                .querySelectorAll<HTMLElement>('[data-dock-root]')
                .forEach((root) => measureDockRoot(root));
        };

        const scheduleDockLayout = () => {
            if (dockLayoutFrame !== null) return;
            dockLayoutFrame = window.requestAnimationFrame(updateDockLayout);
        };

        const observeDockRoots = () => {
            dockResizeObserver?.disconnect();
            dockResizeObserver = null;

            if ('ResizeObserver' in window) {
                dockResizeObserver = new ResizeObserver(scheduleDockLayout);
                document.querySelectorAll('[data-dock-root]').forEach((root) => {
                    dockResizeObserver?.observe(root);
                });
            }

            scheduleDockLayout();
        };

        observeDockRoots();

        window.addEventListener('resize', scheduleDockLayout, { passive: true });
        window.addEventListener('orientationchange', scheduleDockLayout, { passive: true });
        document.addEventListener('astro:after-swap', observeDockRoots);
        document.fonts?.ready.then(scheduleDockLayout).catch(() => undefined);
    }
</script>
