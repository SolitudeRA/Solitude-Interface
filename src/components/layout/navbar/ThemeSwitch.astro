<button
    type="button"
    role="switch"
    aria-checked="false"
    aria-label="Switch to light theme"
    data-theme-switch
    data-state="unchecked"
    class:list={[
        'peer inline-flex h-8 w-14 shrink-0 cursor-pointer items-center rounded-full',
        'border transition-all duration-300',
        'border-[var(--top-control-border)] bg-[var(--top-control-bg)] text-[var(--top-control-text)]',
        'shadow-[0_8px_24px_var(--top-control-shadow)] hover:bg-[var(--top-control-bg-hover)] hover:shadow-[0_10px_28px_var(--top-control-shadow-hover)]',
        'focus-visible:ring-ring focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:outline-none',
    ]}
>
    <span
        data-theme-switch-thumb
        data-state="unchecked"
        class:list={[
            'pointer-events-none flex h-6 w-6 items-center justify-center rounded-full',
            'transition-all duration-300',
            'data-[state=checked]:translate-x-7 data-[state=unchecked]:translate-x-1',
            'bg-[var(--top-control-thumb-bg)] text-[var(--top-control-thumb-text)]',
            'shadow-[0_6px_18px_var(--top-control-thumb-shadow)]',
        ]}
    >
        <svg
            data-theme-switch-icon="sun"
            class="hidden h-4 w-4 text-current transition-transform duration-300"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg
            data-theme-switch-icon="moon"
            class="h-4 w-4 text-current transition-transform duration-300"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
        >
            <path
                d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"
            ></path>
        </svg>
    </span>
</button>

<script is:inline>
    (() => {
        const STORAGE_KEY = 'theme';
        const TOGGLE_SELECTOR = '[data-theme-switch]';
        const THEMES = new Set(['dark', 'light']);

        const isTheme = (value) => THEMES.has(value);

        const getDocumentTheme = () => {
            const root = document.documentElement;
            if (root.classList.contains('light')) return 'light';
            if (root.classList.contains('dark')) return 'dark';
            return 'dark';
        };

        const getStoredTheme = () => {
            let storedTheme = null;

            try {
                storedTheme = window.localStorage.getItem(STORAGE_KEY);
            } catch {
                return getDocumentTheme();
            }

            if (!storedTheme) return getDocumentTheme();
            if (isTheme(storedTheme)) return storedTheme;

            try {
                const parsed = JSON.parse(storedTheme);
                return isTheme(parsed) ? parsed : getDocumentTheme();
            } catch {
                return getDocumentTheme();
            }
        };

        const setToggleState = (button, theme) => {
            const isLight = theme === 'light';
            const state = isLight ? 'checked' : 'unchecked';
            const thumb = button.querySelector('[data-theme-switch-thumb]');
            const sunIcon = button.querySelector('[data-theme-switch-icon="sun"]');
            const moonIcon = button.querySelector('[data-theme-switch-icon="moon"]');

            button.setAttribute('aria-checked', String(isLight));
            button.setAttribute(
                'aria-label',
                isLight ? 'Switch to dark theme' : 'Switch to light theme'
            );
            button.dataset.state = state;
            thumb?.setAttribute('data-state', state);

            if (sunIcon instanceof SVGElement) sunIcon.classList.toggle('hidden', !isLight);
            if (moonIcon instanceof SVGElement) moonIcon.classList.toggle('hidden', isLight);
        };

        const setAllToggleStates = (theme) => {
            document.querySelectorAll(TOGGLE_SELECTOR).forEach((button) => {
                if (button instanceof HTMLButtonElement) {
                    setToggleState(button, theme);
                }
            });
        };

        const applyTheme = (theme, shouldPersist = true) => {
            document.documentElement.classList.toggle('dark', theme === 'dark');
            document.documentElement.classList.toggle('light', theme === 'light');
            setAllToggleStates(theme);

            if (shouldPersist) {
                try {
                    window.localStorage.setItem(STORAGE_KEY, JSON.stringify(theme));
                } catch {
                    // Keep the visible control interactive even when storage is unavailable.
                }
            }

            window.dispatchEvent(
                new CustomEvent('themeChanged', {
                    detail: { theme },
                })
            );
        };

        const bindToggle = (button) => {
            if (
                !(button instanceof HTMLButtonElement) ||
                button.dataset.themeSwitchBound === 'true'
            ) {
                return;
            }

            button.dataset.themeSwitchBound = 'true';
            button.addEventListener('click', () => {
                const nextTheme = button.getAttribute('aria-checked') === 'true' ? 'dark' : 'light';
                applyTheme(nextTheme);
            });
        };

        const initialTheme = getStoredTheme();
        applyTheme(initialTheme, false);
        document.querySelectorAll(TOGGLE_SELECTOR).forEach(bindToggle);

        window.addEventListener('themeChanged', (event) => {
            const theme = event.detail?.theme;
            if (isTheme(theme)) setAllToggleStates(theme);
        });
    })();
</script>
