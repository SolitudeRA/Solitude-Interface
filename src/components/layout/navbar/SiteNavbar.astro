---
import SmartNavbar from './SmartNavbar.tsx';
import NavbarBrand from './NavbarBrand.astro';
import NavbarUtility from './NavbarUtility.astro';
import type { Locale } from '@lib/i18n';

interface Props {
    logoUrl: string;
    siteTitle: string;
    siteSubTitle: string;
    homeUrl?: string;
    isFixed?: boolean;
    readerMode?: boolean;
    availableLocales?: readonly Locale[] | undefined;
    displayLocale?: Locale | undefined;
}

const {
    logoUrl,
    siteTitle,
    siteSubTitle,
    homeUrl = '/',
    isFixed = false,
    readerMode = false,
    availableLocales,
    displayLocale,
} = Astro.props;
---

<SmartNavbar isFixed={isFixed} readerMode={readerMode} client:load>
    <NavbarBrand
        logoImageUrl={logoUrl}
        siteTitle={siteTitle}
        siteSubTitle={siteSubTitle}
        homeUrl={homeUrl}
    />
    <NavbarUtility availableLocales={availableLocales} displayLocale={displayLocale} />
</SmartNavbar>
