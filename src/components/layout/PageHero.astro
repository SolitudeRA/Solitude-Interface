---
/**
 * PageHero - 可复用的页面 Hero 区域组件
 * 用于 about、contact、privacy-policy 等静态页面
 */

interface Props {
    /** 页面标题 */
    title: string;
    /** 背景图片 URL */
    backgroundImage?: string | undefined;
    /** Hero 视觉变体 */
    variant?: 'default' | 'profile';
    /** 副标题/描述（可选） */
    subtitle?: string;
    /** 简短事实标签（可选） */
    facts?: string[];
    /** 徽章文本（可选） */
    badgeText?: string;
    /** 徽章图标（可选，传入 slot） */
    badgeIcon?: boolean;
    /** 日期（可选） */
    date?: string;
}

const {
    title,
    backgroundImage,
    variant = 'default',
    subtitle,
    facts = [],
    badgeText,
    badgeIcon = false,
    date,
} = Astro.props;
---

<div
    class:list={['page-hero', variant !== 'default' && `page-hero--${variant}`]}
    style={backgroundImage ? `--bg-image: url(${backgroundImage})` : ''}
>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
        <h1 class="page-hero-title">{title}</h1>

        {
            (badgeText || date) && (
                <div class="page-hero-meta">
                    {badgeText && (
                        <span class="page-badge">
                            {badgeIcon && <slot name="badge-icon" />}
                            {badgeText}
                        </span>
                    )}
                    {date && (
                        <time datetime={date} class="page-date">
                            {date}
                        </time>
                    )}
                </div>
            )
        }

        {
            facts.length > 0 && (
                <div class="page-hero-facts" aria-label="Profile highlights">
                    {facts.map((fact) => (
                        <span class="page-hero-fact">{fact}</span>
                    ))}
                </div>
            )
        }

        {facts.length === 0 && subtitle && <p class="page-hero-subtitle">{subtitle}</p>}
    </div>
</div>

<style>
    .page-hero {
        position: relative;
        height: 50vh;
        min-height: 350px;
        width: 100%;
        background-image: var(
            --bg-image,
            linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%)
        );
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: scroll;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        isolation: isolate;
        margin-top: calc(max(60px, 12svh) + 0.5rem);
        margin-bottom: -1px;
        --hero-overlay-start: var(--page-hero-overlay-start, oklch(0.985 0.006 250 / 0.22));
        --hero-overlay-mid: var(--page-hero-overlay-mid, oklch(0.96 0.012 250 / 0.5));
        --hero-overlay-end: var(--page-hero-overlay-end, var(--background));
    }

    .page-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            180deg,
            var(--hero-overlay-start) 0%,
            var(--hero-overlay-mid) 50%,
            var(--hero-overlay-end) 95%,
            var(--hero-overlay-end) 100%
        );
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
    }

    .page-hero-content {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 0 2rem;
        max-width: 800px;
    }

    .page-hero--profile {
        height: clamp(20rem, 42svh, 28.75rem);
        min-height: 20rem;
    }

    .page-hero--profile .page-hero-content {
        max-width: 48rem;
        padding: 0 1.5rem;
    }

    .page-hero-title {
        font-size: 4rem;
        font-weight: 700;
        color: var(--foreground);
        margin-bottom: 1.5rem;
        letter-spacing: 0;
        text-shadow: var(--page-hero-title-shadow);
    }

    .page-hero--profile .page-hero-title {
        margin-bottom: 1.25rem;
        font-size: 3.5rem;
    }

    .page-hero-subtitle {
        font-size: 1.25rem;
        color: var(--page-hero-meta);
        margin-top: 1rem;
        line-height: 1.6;
        text-wrap: balance;
    }

    .page-hero-meta {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .page-hero-facts {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.625rem;
        margin-top: 1rem;
    }

    .page-hero-fact {
        display: inline-flex;
        align-items: center;
        min-height: 2rem;
        padding: 0.375rem 0.875rem;
        color: var(--page-hero-meta);
        font-size: 0.9375rem;
        font-weight: 600;
        line-height: 1.35;
        white-space: nowrap;
        background: color-mix(in oklch, var(--page-hero-badge-bg) 82%, transparent);
        border: 1px solid var(--page-hero-badge-border);
        border-radius: 9999px;
        box-shadow:
            0 10px 26px var(--page-surface-shadow),
            0 1px 0 oklch(1 0 0 / 0.26) inset;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .page-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 0.875rem;
        font-size: 0.875rem;
        font-weight: 500;
        background: var(--page-hero-badge-bg);
        color: var(--page-badge-text);
        border-radius: 9999px;
        border: 1px solid var(--page-hero-badge-border);
        box-shadow:
            0 12px 28px var(--page-surface-shadow),
            0 1px 0 oklch(1 0 0 / 0.32) inset;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .page-badge :global(svg) {
        width: 1rem;
        height: 1rem;
    }

    .page-date {
        font-size: 1.125rem;
        color: var(--page-hero-meta);
    }

    @media (min-width: 640px) {
        .page-hero {
            margin-top: calc(max(70px, 13svh) + 0.5rem);
        }
    }

    @media (min-width: 768px) {
        .page-hero {
            margin-top: calc(max(80px, 14svh) + 0.5rem);
        }
    }

    @media (max-width: 768px) {
        .page-hero {
            height: 40vh;
            min-height: 280px;
        }

        .page-hero-title {
            font-size: 2.5rem;
        }

        .page-hero--profile {
            height: clamp(18rem, 38svh, 22rem);
            min-height: 18rem;
        }

        .page-hero--profile .page-hero-title {
            font-size: 2.5rem;
        }

        .page-hero-subtitle {
            font-size: 1rem;
        }

        .page-hero-facts {
            gap: 0.5rem;
        }

        .page-hero-fact {
            min-height: 1.875rem;
            padding: 0.3125rem 0.75rem;
            font-size: 0.875rem;
        }
    }

    @media (max-width: 420px) {
        .page-hero--profile .page-hero-title {
            font-size: 2.25rem;
        }

        .page-hero-fact {
            white-space: normal;
        }
    }

    /* ===== 深色模式样式（白色文字 + 暖色装饰） ===== */
    :global(.dark) .page-hero-title {
        color: var(--foreground);
    }

    :global(.dark) .page-hero-subtitle {
        color: var(--text-content-primary);
    }

    :global(.dark) .page-badge {
        background: var(--article-content-code-bg);
        color: var(--page-badge-text);
        border-color: var(--article-content-pre-border);
    }

    :global(.dark) .page-badge :global(svg) {
        color: var(--page-icon);
    }

    :global(.dark) .page-date {
        color: var(--text-content-primary);
    }
</style>
