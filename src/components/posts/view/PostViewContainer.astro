---
import type { Post } from '@api/ghost/types';
import { PostType } from '@api/ghost/types';
import DefaultCard from './cards/DefaultCard.astro';
import ArticleCard from './cards/ArticleCard.astro';
import MusicCard from './cards/MusicCard.astro';
import VideoCard from './cards/VideoCard.astro';
import GalleryCard from './cards/GalleryCard.astro';
import PostViewScrollContainer from './PostViewScrollContainer';
import { DEFAULT_LOCALE, getUIText, type Locale } from '@lib/i18n';

interface Props {
    posts: Post[];
    locale?: Locale;
    /** 画廊末尾「查看全部」入口卡的文案；省略则不渲染入口卡 */
    viewAllLabel?: string;
}

const { posts, locale = DEFAULT_LOCALE, viewAllLabel } = Astro.props;

// 提取所有文章的发布日期
const postDates = posts.map((post) => post.published_at);
const noPostsText = getUIText('home', 'noPosts', locale);
---

{
    posts.length > 0 ? (
        <PostViewScrollContainer client:idle postDates={postDates}>
            {posts.map((post, index) => {
                const PostCardComponent = (() => {
                    switch (post.post_type) {
                        case PostType.DEFAULT:
                            return DefaultCard;
                        case PostType.ARTICLE:
                            return ArticleCard;
                        case PostType.MUSIC:
                            return MusicCard;
                        case PostType.VIDEO:
                            return VideoCard;
                        case PostType.GALLERY:
                            return GalleryCard;
                        default:
                            return DefaultCard;
                    }
                })();

                return (
                    <a
                        href={post.url.toString()}
                        class="post-card-wrapper flex shrink-0 items-center justify-center rounded-[35px] transition-all duration-300 ease-out hover:z-10 hover:scale-[1.02] focus-visible:ring-2 focus-visible:ring-[var(--ring)] focus-visible:ring-offset-2 focus-visible:outline-none"
                        role="listitem"
                        aria-label={post.title}
                    >
                        <PostCardComponent post={post} locale={locale} priority={index < 2} />
                    </a>
                );
            })}
            {viewAllLabel && (
                <button
                    type="button"
                    data-view-switch="list"
                    class="post-card-wrapper post-view-all-card flex shrink-0 cursor-pointer flex-col items-center justify-center gap-4 rounded-[35px] border border-dashed border-[var(--border)] bg-[var(--card)]/40 text-[var(--muted-foreground)] transition-all duration-300 ease-out hover:scale-[1.02] hover:border-[var(--ring)] hover:text-[var(--foreground)] focus-visible:ring-2 focus-visible:ring-[var(--ring)] focus-visible:ring-offset-2 focus-visible:outline-none"
                    aria-label={viewAllLabel}
                >
                    <span
                        class="flex h-14 w-14 items-center justify-center rounded-full border border-[var(--border)] bg-[var(--background)]/60 text-2xl"
                        aria-hidden="true"
                    >
                        &rarr;
                    </span>
                    <span class="px-6 text-center text-sm font-semibold">{viewAllLabel}</span>
                </button>
            )}
        </PostViewScrollContainer>
    ) : (
        <section class="post-view-empty flex h-[75svh] min-h-[420px] items-center justify-center px-6">
            <p class="rounded-lg border border-[var(--border)] bg-[var(--background)]/70 px-5 py-3 text-sm font-medium text-[var(--muted-foreground)] shadow-sm backdrop-blur-sm">
                {noPostsText}
            </p>
        </section>
    )
}

<style>
    .post-card-wrapper {
        --post-card-height: clamp(500px, min(72svh, calc(100svh - 220px)), 780px);
        --post-card-width: clamp(250px, calc(var(--post-card-height) / 1.98), 394px);

        width: var(--post-card-width);
        height: var(--post-card-height);
    }

    @media (pointer: coarse) {
        .post-card-wrapper {
            --post-card-height: clamp(430px, min(68svh, 560px), 560px);
            --post-card-width: clamp(240px, calc(var(--post-card-height) / 1.98), 320px);
        }
    }

    @media (pointer: fine) and (max-height: 780px) {
        .post-card-wrapper {
            --post-card-height: clamp(460px, calc(100svh - 220px), 560px);
            --post-card-width: clamp(240px, calc(var(--post-card-height) / 1.98), 320px);
        }
    }

    @media (pointer: fine) and (min-width: 1920px) {
        .post-card-wrapper {
            --post-card-height: clamp(620px, min(72svh, calc(100svh - 220px)), 820px);
            --post-card-width: clamp(300px, calc(var(--post-card-height) / 1.98), 428px);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .post-card-wrapper {
            transition: none;
        }

        .post-card-wrapper:hover {
            transform: none;
        }
    }
</style>
