---
import type { Post } from '@api/ghost/types';
import { DEFAULT_LOCALE, type Locale } from '@lib/i18n';
import BaseCard from './BaseCard.astro';

interface Props {
    post: Post;
    locale?: Locale;
    priority?: boolean;
}

const { post, locale = DEFAULT_LOCALE, priority = false } = Astro.props;
---

<BaseCard post={post} typeIcon="🎬" locale={locale} priority={priority} />
