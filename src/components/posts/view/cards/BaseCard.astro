---
import type { Post } from '@api/ghost/types';
import { Chip } from '@components/common/badge';

// 颜色方案类型（与 badge.tsx 保持一致）
type ChipColorScheme =
    | 'default'
    | 'primary'
    | 'secondary'
    | 'success'
    | 'warning'
    | 'info'
    | 'purple'
    | 'rose';

// Type 配置：不同文章类型使用不同颜色
const DEFAULT_TYPE_CONFIG = {
    colorScheme: 'secondary' as ChipColorScheme,
};

const TYPE_CONFIG: Record<string, { colorScheme: ChipColorScheme }> = {
    article: { colorScheme: 'primary' }, // 蓝色 - 经典、专业
    gallery: { colorScheme: 'purple' }, // 紫色 - 艺术、创意
    video: { colorScheme: 'rose' }, // 玫红 - 热情、动感
    music: { colorScheme: 'warning' }, // 琥珀 - 温暖、活力
    default: DEFAULT_TYPE_CONFIG,
};

// Category 配置：不同分类使用不同颜色和图标
const DEFAULT_CATEGORY_CONFIG = {
    icon: '📂',
    colorScheme: 'secondary' as ChipColorScheme,
};

const CATEGORY_CONFIG: Record<string, { icon: string; colorScheme: ChipColorScheme }> = {
    tech: { icon: '💻', colorScheme: 'info' }, // 青色 - 科技感
    life: { icon: '🌱', colorScheme: 'success' }, // 绿色 - 生活、自然
    default: DEFAULT_CATEGORY_CONFIG,
};

interface Props {
    post: Post;
    /** 卡片类型图标，例如 📝、🖼️、🎵、🎬 */
    typeIcon?: string;
    /** 自定义 CSS 类名 */
    className?: string;
}

const { post, typeIcon, className = '' } = Astro.props;
const postFeatureImageUrl = `url(${post.feature_image.toString()})`;

// 获取 type 配置
const typeKey = post.post_type?.toLowerCase() || 'default';
const typeConfig = TYPE_CONFIG[typeKey] ?? DEFAULT_TYPE_CONFIG;

// 获取 category 配置
const categoryKey = post.post_category?.toLowerCase() || 'default';
const categoryConfig = CATEGORY_CONFIG[categoryKey] ?? DEFAULT_CATEGORY_CONFIG;
---

<div
    class:list={[
        'base-card flex h-full w-full flex-col rounded-[35px] px-7 py-8 shadow-lg transition-all duration-300 hover:shadow-2xl',
        className,
    ]}
    style={`--postFeatureImageUrl: ${postFeatureImageUrl}`}
>
    <!-- 顶部标签区 -->
    <div class="mb-5 flex items-center justify-between">
        <Chip variant="flat" colorScheme={typeConfig.colorScheme}>
            {typeIcon && <span class="mr-1">{typeIcon}</span>}
            {post.post_type}
        </Chip>
        {
            post.post_category && (
                <Chip variant="flat" colorScheme={categoryConfig.colorScheme}>
                    <span class="mr-1">{categoryConfig.icon}</span>
                    {post.post_category}
                </Chip>
            )
        }
    </div>

    <!-- 标题区 -->
    <div class="mt-2 mb-6">
        <h3
            class="card-title line-clamp-3 text-center text-[1.75rem] leading-relaxed font-medium tracking-normal"
        >
            {post.title}
        </h3>
    </div>

    <!-- 自定义内容插槽（用于特殊卡片的图标/装饰区域） -->
    <slot name="richtext" />

    <!-- 摘要区（flex-1 占据剩余空间） -->
    <div class="mb-auto flex-1 overflow-hidden">
        <p class="card-excerpt line-clamp-5 text-[1.05rem] leading-[1.85] tracking-wide">
            {post.excerpt}
        </p>
    </div>

    <!-- 分隔装饰线 - 彩虹渐变 -->
    <div class="card-divider mx-auto my-4 h-0.5 w-3/7 rounded-full"></div>

    <!-- 底部信息区 -->
    <div class="mt-auto space-y-3">
        <div class="card-meta text-center text-xs font-medium tracking-wide">
            {post.published_at.split('T')[0]}
        </div>
        {
            post.post_general_tags && post.post_general_tags.length > 0 && (
                <div class="flex flex-wrap justify-center gap-1.5">
                    {post.post_general_tags.slice(0, 3).map((tagName: string) => (
                        <Chip colorScheme="success" variant="flat">
                            {tagName}
                        </Chip>
                    ))}
                </div>
            )
        }
    </div>
</div>

<style>
    .base-card {
        position: relative;
        background-size: cover;
        background-position: center;
        background-image: var(--postFeatureImageUrl);
        box-shadow: 0 8px 32px var(--post-view-card-shadow);
    }

    /* 彩虹色亮边 - 使用伪元素实现 */
    .base-card::after {
        content: '';
        position: absolute;
        inset: -1px;
        border-radius: inherit;
        padding: 1px;
        background: conic-gradient(
            from 0deg,
            #ff6b6b,
            #feca57,
            #48dbfb,
            #ff9ff3,
            #54a0ff,
            #5f27cd,
            #ff6b6b
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
        opacity: 0.6;
        transition: opacity 0.3s ease;
        z-index: 0;
    }

    .base-card:hover::after {
        opacity: 0.9;
    }

    /* 渐变覆盖层 */
    .base-card::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: linear-gradient(
            180deg,
            var(--post-view-card-overlay-start) 0%,
            var(--post-view-card-overlay-mid) 50%,
            var(--post-view-card-overlay-end) 100%
        );
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    /* 确保内容在覆盖层之上 */
    .base-card > * {
        position: relative;
        z-index: 1;
    }

    /* 文字颜色 - 使用主题变量提高可读性 */
    .card-title {
        color: var(--post-view-card-title);
        text-shadow: 0 1px 2px rgba(255, 255, 255, 0.3);
    }

    .card-excerpt {
        color: var(--post-view-card-excerpt);
        text-shadow: 0 1px 1px rgba(255, 255, 255, 0.2);
    }

    .card-meta {
        color: var(--post-view-card-meta);
        letter-spacing: 0.05em;
    }

    .card-divider {
        background: linear-gradient(
            90deg,
            transparent 0%,
            #ff6b6b 10%,
            #feca57 25%,
            #48dbfb 40%,
            #ff9ff3 55%,
            #54a0ff 70%,
            #5f27cd 85%,
            transparent 100%
        );
        opacity: 0.35;
        transition: opacity 0.3s ease;
    }

    .base-card:hover .card-divider {
        opacity: 0.55;
    }

    /* 暗色主题文字阴影调整 */
    :global(.dark) .card-title {
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
    }

    :global(.dark) .card-excerpt {
        text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    }

    /* 悬停效果增强 */
    .base-card:hover {
        box-shadow: 0 12px 48px var(--post-view-card-shadow-hover);
    }

    .base-card:hover::before {
        opacity: 0.85;
    }

    /* 响应式优化 - 大屏幕增加 padding */
    @media (min-width: 1440px) {
        .base-card {
            padding: 2.25rem 2rem;
        }
    }

    @media (min-width: 1920px) {
        .base-card {
            padding: 2.5rem 2.25rem;
        }
    }
</style>
