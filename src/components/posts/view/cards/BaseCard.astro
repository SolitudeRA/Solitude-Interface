---
import type { Post } from '@api/ghost/types';
import { DEFAULT_LOCALE, type Locale } from '@lib/i18n';

interface Props {
    post: Post;
    /** Kept for the typed media-card wrappers; the visual type label comes from Ghost tags. */
    typeIcon?: string;
    locale?: Locale;
    className?: string;
}

const { post, locale = DEFAULT_LOCALE, className = '' } = Astro.props;

const featureImageUrl = post.feature_image?.toString() ?? '';
const hasFeatureImage = featureImageUrl.length > 0;

const PREVIEW_LIMITS: Record<Locale, number> = {
    zh: 145,
    ja: 145,
    en: 265,
};

function isVisibleTag(value: string | null | undefined): value is string {
    return Boolean(value && value.trim() && value.trim().toLowerCase() !== 'default');
}

function titleCaseTag(value: string): string {
    return value
        .trim()
        .replace(/[-_]+/g, ' ')
        .replace(/\b[a-z]/g, (char) => char.toUpperCase());
}

function truncatePreview(value: string | null | undefined, maxLength: number): string {
    const normalized = (value ?? '').trim().replace(/\s+/g, ' ');
    const chars = Array.from(normalized);

    if (chars.length <= maxLength) return normalized;

    const suffix = '...';
    const sliceLength = Math.max(0, maxLength - suffix.length);

    return `${chars.slice(0, sliceLength).join('').trimEnd()}${suffix}`;
}

function getTitleDensity(
    title: string,
    currentLocale: Locale
): 'short' | 'medium' | 'long' | 'stress' {
    const length = Array.from(title.trim()).length;

    if (currentLocale === 'en') {
        if (length > 90) return 'stress';
        if (length > 58) return 'long';
        if (length > 28) return 'medium';
        return 'short';
    }

    if (length > 50) return 'stress';
    if (length > 32) return 'long';
    if (length > 18) return 'medium';
    return 'short';
}

const previewText = truncatePreview(post.excerpt, PREVIEW_LIMITS[locale]);
const publishedDate = post.published_at?.split('T')[0] ?? '';

const typeLabel = isVisibleTag(post.post_type) ? titleCaseTag(post.post_type) : '';
const categoryLabel = isVisibleTag(post.post_category) ? titleCaseTag(post.post_category) : '';
const seriesLabel = isVisibleTag(post.post_series) ? post.post_series.trim() : '';
const seriesNumber = seriesLabel ? (post.post_series_number ?? '') : '';
const titleDensity = getTitleDensity(post.title, locale);
const generalTags = (post.post_general_tags ?? []).filter(isVisibleTag);
---

<div
    class:list={['base-card', className]}
    data-title-density={titleDensity}
    data-card-locale={locale}
>
    {
        hasFeatureImage ? (
            <img
                class="base-card-media base-card-image"
                src={featureImageUrl}
                alt=""
                loading="lazy"
                decoding="async"
            />
        ) : (
            <div class="base-card-media base-card-image-fallback" aria-hidden="true" />
        )
    }

    <div class="base-card-shade" aria-hidden="true"></div>

    <div class="corner-grid" aria-label="Ghost tag groups">
        <div class="corner-zone" aria-label="Post type">
            {typeLabel && <span class="corner-value is-type">{typeLabel}</span>}
        </div>
        <div class="corner-zone" aria-label="Post series">
            {
                (seriesLabel || seriesNumber) && (
                    <span class="corner-series">
                        {seriesLabel && <span class="corner-value is-series">{seriesLabel}</span>}
                        {seriesNumber && (
                            <span class="corner-value is-series-number">{seriesNumber}</span>
                        )}
                    </span>
                )
            }
        </div>
        <div class="corner-zone" aria-label="General tags">
            {
                generalTags.length > 0 && (
                    <span class="corner-tags">
                        {generalTags.map((tagName) => (
                            <span class="corner-tag">{tagName}</span>
                        ))}
                    </span>
                )
            }
        </div>
        <div class="corner-zone" aria-label="Post category">
            {categoryLabel && <span class="corner-value is-category">{categoryLabel}</span>}
        </div>
    </div>

    <div class="card-inner">
        <header class="title-section">
            <h3 class="card-title">{post.title}</h3>
        </header>

        {
            previewText && (
                <section class="content-section">
                    <p class="card-excerpt">{previewText}</p>
                </section>
            )
        }

        <footer class="meta-section">
            {
                publishedDate && (
                    <time class="card-date" datetime={publishedDate}>
                        {publishedDate}
                    </time>
                )
            }
        </footer>
    </div>
</div>

<style>
    .base-card {
        --corner-inset: clamp(16px, 5.8cqw, 24px);
        --corner-pill-bg: var(--post-view-media-card-pill-bg, rgba(255, 255, 255, 0.1));
        --corner-pill-border: var(--post-view-media-card-pill-border, rgba(255, 255, 255, 0.24));

        container-type: inline-size;
        position: relative;
        isolation: isolate;
        height: 100%;
        width: 100%;
        overflow: hidden;
        border: 1px solid var(--post-view-media-card-border, rgba(255, 255, 255, 0.2));
        border-radius: 35px;
        background: var(--post-view-media-card-bg, #0f172a);
        box-shadow: var(
            --post-view-media-card-shadow,
            0 34px 80px rgba(0, 0, 0, 0.38),
            0 1px 0 rgba(255, 255, 255, 0.22) inset
        );
        transition:
            border-color 360ms ease,
            box-shadow 360ms ease;
    }

    :global(.post-card-wrapper:hover) .base-card,
    :global(.post-card-wrapper:focus-visible) .base-card,
    .base-card:hover {
        border-color: var(--post-view-media-card-border-hover, rgba(255, 255, 255, 0.32));
        box-shadow: var(
            --post-view-media-card-shadow-hover,
            0 38px 84px rgba(0, 0, 0, 0.42),
            0 1px 0 rgba(255, 255, 255, 0.26) inset
        );
    }

    :global(.post-card-wrapper:active) .base-card {
        border-color: var(--post-view-media-card-border-active, rgba(255, 255, 255, 0.26));
        box-shadow: var(
            --post-view-media-card-shadow-active,
            0 30px 72px rgba(0, 0, 0, 0.38),
            0 1px 0 rgba(255, 255, 255, 0.22) inset
        );
    }

    .base-card-media,
    .base-card-shade,
    .card-inner {
        position: absolute;
        inset: 0;
    }

    .base-card-media {
        z-index: 0;
        height: 100%;
        width: 100%;
        object-fit: cover;
        filter: var(--post-view-media-card-filter, saturate(1.05) contrast(0.98));
        transform: scale(1.025) translate3d(0, 0, 0);
        transition:
            transform 700ms cubic-bezier(0.22, 1, 0.36, 1),
            filter 700ms ease;
    }

    .base-card-image-fallback {
        background:
            radial-gradient(
                circle at 30% 20%,
                var(--card-image-fallback-highlight),
                transparent 32%
            ),
            linear-gradient(
                135deg,
                var(--card-image-fallback-start),
                var(--card-image-fallback-end)
            );
    }

    .base-card-shade {
        z-index: 1;
        background: var(--post-view-media-card-shade);
        pointer-events: none;
    }

    .base-card-shade::after {
        position: absolute;
        inset: 0;
        background: var(--post-view-media-card-glow);
        content: '';
        opacity: 0;
        transform: translate3d(0, 10px, 0);
        transition:
            opacity 520ms ease,
            transform 520ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    :global(.post-card-wrapper:hover) .base-card-media,
    :global(.post-card-wrapper:focus-visible) .base-card-media,
    .base-card:hover .base-card-media {
        filter: var(--post-view-media-card-filter-hover, saturate(1.12) contrast(1.02));
        transform: scale(1.04) translate3d(0, 0, 0);
    }

    :global(.post-card-wrapper:hover) .base-card-shade::after,
    :global(.post-card-wrapper:focus-visible) .base-card-shade::after,
    .base-card:hover .base-card-shade::after {
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }

    .corner-grid {
        position: absolute;
        inset: var(--corner-inset);
        z-index: 4;
        display: grid;
        grid-template-rows: auto 1fr auto;
        grid-template-columns: auto minmax(0, 1fr);
        column-gap: 8px;
        pointer-events: none;
    }

    .corner-zone {
        display: grid;
        max-width: min(148px, 42cqw);
        gap: 5px;
        pointer-events: none;
    }

    .corner-zone:nth-child(1) {
        grid-column: 1;
        grid-row: 1;
    }

    .corner-zone:nth-child(2) {
        grid-column: 2;
        grid-row: 1;
        width: 100%;
        max-width: none;
        min-width: 0;
        justify-items: end;
    }

    .corner-zone:nth-child(3) {
        grid-column: 1;
        grid-row: 3;
        pointer-events: auto;
    }

    .corner-zone:nth-child(4) {
        grid-column: 2;
        grid-row: 3;
    }

    .corner-zone:nth-child(2),
    .corner-zone:nth-child(4) {
        justify-self: end;
        text-align: right;
    }

    .corner-zone:nth-child(3),
    .corner-zone:nth-child(4) {
        align-self: end;
    }

    .corner-value,
    .corner-tag {
        display: inline-flex;
        min-height: clamp(22px, 6.6cqw, 26px);
        align-items: center;
        border: 1px solid var(--corner-pill-border);
        border-radius: 999px;
        background: var(--corner-pill-bg);
        color: var(--post-view-media-card-pill-text, rgba(255, 255, 255, 0.9));
        font-size: clamp(0.625rem, 2.8cqw, 0.6875rem);
        font-weight: 800;
        line-height: 1;
        text-shadow: 0 1px 8px rgba(3, 7, 18, 0.5);
        white-space: nowrap;
    }

    .corner-series {
        display: inline-flex;
        width: fit-content;
        max-width: 100%;
        min-width: 0;
        flex-wrap: nowrap;
        justify-content: flex-end;
        align-items: center;
        gap: 5px;
    }

    .corner-value {
        justify-self: start;
        max-width: 148px;
        overflow: hidden;
        padding: 4px 10px;
        text-overflow: ellipsis;
    }

    .corner-zone:nth-child(2) .corner-value,
    .corner-zone:nth-child(4) .corner-value {
        justify-self: end;
    }

    .corner-value.is-type {
        border-color: rgba(125, 211, 252, 0.52);
        background: rgba(125, 211, 252, 0.16);
    }

    .corner-value.is-series {
        min-width: 0;
        max-width: none;
        flex: 1 1 auto;
        border-color: rgba(253, 164, 175, 0.42);
        background: rgba(253, 164, 175, 0.14);
    }

    .corner-value.is-series-number {
        flex: 0 0 auto;
        border-color: rgba(196, 181, 253, 0.48);
        background: rgba(196, 181, 253, 0.16);
    }

    .corner-value.is-category {
        border-color: rgba(190, 242, 100, 0.42);
        background: rgba(190, 242, 100, 0.13);
    }

    .corner-tags {
        display: flex;
        width: fit-content;
        max-width: 150px;
        flex-flow: column-reverse wrap;
        justify-content: flex-start;
        gap: 5px;
        pointer-events: auto;
    }

    .corner-tag {
        max-width: 92px;
        overflow: hidden;
        padding: 4px 8px;
        text-overflow: ellipsis;
        transform: translate3d(0, 0, 0);
        transition:
            border-color 180ms ease,
            background 180ms ease,
            opacity 180ms ease,
            transform 180ms ease;
    }

    .corner-zone:nth-child(3) .corner-tag:nth-child(n + 4) {
        display: none;
    }

    .corner-tags:hover .corner-tag:nth-child(n + 4),
    .corner-zone:nth-child(3):hover .corner-tag:nth-child(n + 4),
    :global(.post-card-wrapper:hover) .corner-zone:nth-child(3) .corner-tag:nth-child(n + 4),
    :global(.post-card-wrapper:focus-visible)
        .corner-zone:nth-child(3)
        .corner-tag:nth-child(n + 4),
    .base-card:hover .corner-zone:nth-child(3) .corner-tag:nth-child(n + 4) {
        display: inline-flex;
        animation: tag-reveal 280ms cubic-bezier(0.22, 1, 0.36, 1) both;
    }

    .card-inner {
        z-index: 3;
        display: grid;
        grid-template-rows: minmax(160px, auto) minmax(0, 1fr) minmax(88px, auto);
        gap: clamp(10px, 3cqw, 16px);
        padding: clamp(18px, 6cqw, 28px);
        pointer-events: none;
    }

    .title-section {
        display: grid;
        min-width: 0;
        align-content: end;
        justify-items: center;
        padding: clamp(48px, 14cqw, 64px) clamp(8px, 3cqw, 18px) 0;
    }

    .card-title {
        display: -webkit-box;
        max-width: 11ch;
        margin: 0;
        overflow: hidden;
        color: var(--post-view-media-card-title, #fff);
        font-size: clamp(1.5rem, 8.6cqw, 2.125rem);
        font-weight: 880;
        letter-spacing: 0;
        line-height: 1.1;
        text-align: center;
        text-shadow: var(--post-view-media-card-title-shadow, 0 2px 14px rgba(3, 7, 18, 0.82));
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 4;
    }

    .base-card[data-title-density='long'] .card-title {
        max-width: 13ch;
        font-size: clamp(1.375rem, 7.6cqw, 1.875rem);
        -webkit-line-clamp: 5;
    }

    .base-card[data-title-density='stress'] .card-title {
        max-width: 15ch;
        font-size: clamp(1.25rem, 6.85cqw, 1.6875rem);
        line-height: 1.12;
        -webkit-line-clamp: 5;
    }

    .content-section {
        display: grid;
        min-width: 0;
        align-content: center;
        justify-items: center;
        padding: 0 clamp(10px, 4cqw, 22px);
    }

    .card-excerpt {
        display: -webkit-box;
        max-width: 26ch;
        margin: 0;
        overflow: hidden;
        color: var(--post-view-media-card-excerpt, rgba(255, 255, 255, 0.86));
        font-size: clamp(0.875rem, 3.8cqw, 1.05rem);
        font-weight: 520;
        line-height: 1.55;
        text-align: center;
        text-shadow: var(--post-view-media-card-copy-shadow, 0 2px 10px rgba(3, 7, 18, 0.72));
        -webkit-box-orient: vertical;
        -webkit-line-clamp: 10;
    }

    .meta-section {
        position: relative;
        min-width: 0;
    }

    .card-date {
        position: absolute;
        bottom: clamp(0px, 1cqw, 2px);
        left: 50%;
        color: var(--post-view-media-card-date, rgba(255, 255, 255, 0.64));
        font-size: clamp(0.625rem, 2.8cqw, 0.6875rem);
        font-variant-numeric: tabular-nums;
        font-weight: 750;
        line-height: 1;
        text-align: center;
        text-shadow: var(--post-view-media-card-copy-shadow, 0 1px 8px rgba(3, 7, 18, 0.66));
        transform: translateX(-50%);
        white-space: nowrap;
    }

    @keyframes tag-reveal {
        from {
            opacity: 0;
            transform: translate3d(0, 10px, 0) scale(0.96);
        }

        to {
            opacity: 1;
            transform: translate3d(0, 0, 0) scale(1);
        }
    }

    @media (max-width: 640px) {
        .base-card {
            border-radius: 28px;
        }

        .card-inner {
            grid-template-rows: minmax(132px, auto) minmax(0, 1fr) minmax(74px, auto);
            padding: clamp(16px, 5.2cqw, 20px);
        }

        .title-section {
            padding-top: clamp(42px, 13cqw, 54px);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .base-card,
        .base-card-media,
        .base-card-shade::after,
        .corner-tag {
            transition: none;
        }

        .corner-tags:hover .corner-tag:nth-child(n + 4),
        .corner-zone:nth-child(3):hover .corner-tag:nth-child(n + 4),
        :global(.post-card-wrapper:hover) .corner-zone:nth-child(3) .corner-tag:nth-child(n + 4),
        :global(.post-card-wrapper:focus-visible)
            .corner-zone:nth-child(3)
            .corner-tag:nth-child(n + 4),
        .base-card:hover .corner-zone:nth-child(3) .corner-tag:nth-child(n + 4) {
            animation: none;
        }
    }
</style>
