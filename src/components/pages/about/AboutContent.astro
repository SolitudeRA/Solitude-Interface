---
/**
 * AboutContent - 关于页面的内容组件
 * 支持多语言
 */
import type { Locale } from '@lib/i18n';
import SteamSnapshot from './SteamSnapshot.astro';
import { aboutI18n, personalProjects, techGroups } from './aboutData';

interface Props {
    locale?: Locale;
}

const { locale = 'zh' } = Astro.props;

const t = aboutI18n[locale];
---

<div class="about-content">
    <!-- 概览 -->
    <section class="about-section about-overview animate-fade-in" style="--delay: 0">
        <div class="section-header">
            <span class="section-badge">👤</span>
            <h2 class="section-title">{t.atAGlance}</h2>
        </div>

        <div class="overview-grid">
            <article class="overview-card overview-card-primary">
                <span class="overview-label">{t.profile}</span>
                <p class="overview-value">{t.intro}</p>
            </article>

            <article class="overview-card">
                <span class="overview-label">{t.spokenLanguages}</span>
                <p class="overview-value">{t.languages}</p>
            </article>

            <article class="overview-card">
                <span class="overview-label">{t.focus}</span>
                <div class="overview-project-list" aria-label={t.focus}>
                    {
                        personalProjects.map((project) => (
                            <a
                                class="overview-project-link"
                                href={project.href}
                                target="_blank"
                                rel="noopener noreferrer"
                            >
                                <span class="overview-project-name">{project.name}</span>
                            </a>
                        ))
                    }
                </div>
            </article>
        </div>
    </section>

    <!-- 技术栈 -->
    <section class="about-section animate-fade-in" style="--delay: 1">
        <div class="section-header">
            <span class="section-badge">⚒️</span>
            <h2 class="section-title">{t.techStack}</h2>
        </div>

        <div class="tech-grid">
            {
                techGroups.map((group) => (
                    <article
                        class:list={['tech-card', group.featured && 'tech-card--featured']}
                        style={`--tech-accent: ${group.accent};`}
                    >
                        <div class="tech-card-header">
                            <span class="tech-card-marker">{group.marker}</span>
                            <h3 class="tech-card-title">{group.title}</h3>
                        </div>

                        <div class="tech-badges">
                            {group.items.map((tech) => {
                                const Icon = tech.icon;
                                const usesLightLogo = tech.color.toLowerCase() === '#ffffff';

                                return (
                                    <span
                                        class:list={[
                                            'tech-badge',
                                            tech.muted && 'tech-badge--muted',
                                            usesLightLogo && 'tech-badge--light-logo',
                                        ]}
                                        style={`--tech-color: ${tech.color};`}
                                        aria-label={tech.name}
                                    >
                                        {Icon ? (
                                            <Icon className="tech-badge-icon" aria-hidden="true" />
                                        ) : (
                                            <span class="tech-badge-fallback" aria-hidden="true">
                                                {tech.fallback}
                                            </span>
                                        )}
                                        <span>{tech.name}</span>
                                    </span>
                                );
                            })}
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <!-- 兴趣爱好 -->
    <section class="about-section animate-fade-in" style="--delay: 2">
        <div class="section-header">
            <span class="section-badge">❤️</span>
            <h2 class="section-title">{t.hobbies}</h2>
        </div>

        <div class="hobbies-grid">
            <!-- 游戏卡片 -->
            <div class="hobby-card hobby-card-gaming">
                <div class="hobby-card-header">
                    <span class="hobby-icon">🎮</span>
                    <div class="hobby-heading">
                        <h3 class="hobby-title">{t.gaming}</h3>
                        <p class="hobby-description">{t.gamingDesc}</p>
                    </div>
                </div>

                <SteamSnapshot locale={locale} />

                <div class="hobby-details gaming-setup-grid">
                    <!-- 主机配置 -->
                    <div class="hobby-detail-row gaming-setup-panel">
                        <div class="detail-header">
                            <span class="detail-icon">🖥️</span>
                            <span class="detail-label">{t.hardwareSpec}</span>
                        </div>
                        <div class="spec-list" aria-label={t.hardwareSpec}>
                            {
                                t.hardwareSpecs.map((spec) => (
                                    <span
                                        class={`spec-chip${spec.featured ? ' spec-chip--featured' : ''}`}
                                    >
                                        <span class="spec-chip-label">{spec.label}</span>
                                        <span class="spec-chip-value">{spec.value}</span>
                                    </span>
                                ))
                            }
                        </div>
                    </div>

                    <!-- 外设 -->
                    <div class="hobby-detail-row gaming-setup-panel">
                        <div class="detail-header">
                            <span class="detail-icon">⌨️</span>
                            <span class="detail-label">{t.peripheral}</span>
                        </div>
                        <div class="peripheral-list">
                            <div class="peripheral-item">
                                <span class="peripheral-type">{t.mouse}</span>
                                <span class="peripheral-value">{t.mouseDetail}</span>
                            </div>
                            <div class="peripheral-item">
                                <span class="peripheral-type">{t.keyboard}</span>
                                <span class="peripheral-value">{t.keyboardDetail}</span>
                            </div>
                            <div class="peripheral-item">
                                <span class="peripheral-type">{t.headset}</span>
                                <span class="peripheral-value">{t.headsetDetail}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 音乐卡片 -->
            <div class="hobby-card hobby-card-music">
                <div class="hobby-card-header">
                    <span class="hobby-icon">🎵</span>
                    <div class="hobby-heading">
                        <h3 class="hobby-title">{t.music}</h3>
                        <p class="hobby-description">{t.musicDesc}</p>
                    </div>
                </div>

                <div class="hobby-details">
                    <!-- 设备 -->
                    <div class="hobby-detail-row">
                        <div class="detail-header">
                            <span class="detail-icon">🎧</span>
                            <span class="detail-label">{t.equipment}</span>
                        </div>
                        <div class="gear-list" aria-label={t.equipment}>
                            {
                                t.equipmentDetail
                                    .split('·')
                                    .map((gear) => <span class="gear-chip">{gear.trim()}</span>)
                            }
                        </div>
                    </div>

                    <!-- 乐器 -->
                    <div class="hobby-detail-row">
                        <div class="detail-header">
                            <span class="detail-icon">🎸</span>
                            <span class="detail-label">{t.instruments}</span>
                        </div>
                        <p class="detail-value">{t.instrumentsDetail}</p>
                    </div>

                    <!-- 乐队经历 -->
                    <div class="hobby-detail-row hobby-detail-row--highlight">
                        <div class="detail-header">
                            <span class="detail-icon">🎤</span>
                            <span class="detail-label">{t.band}</span>
                        </div>
                        <p class="detail-value">{t.bandExp}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    /* ===== 基础布局 ===== */
    .about-content {
        display: flex;
        flex-direction: column;
        gap: 2.25rem;
        padding: 1rem 0;
    }

    .about-section {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeInUp 0.6s ease forwards;
        animation-delay: calc(var(--delay) * 0.12s);
    }

    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ===== Section Header ===== */
    .section-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
    }

    .section-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        font-size: 1rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 0.375rem;
        flex-shrink: 0;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--foreground);
        margin: 0;
        line-height: 1.75rem;
    }

    /* ===== 概览 ===== */
    .overview-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.875rem;
    }

    .overview-card {
        position: relative;
        overflow: hidden;
        padding: 1rem;
        background: var(--page-surface-bg);
        border: 1px solid var(--page-surface-border);
        border-radius: 0.5rem;
        box-shadow: 0 14px 30px var(--page-surface-shadow);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .overview-card-primary {
        background:
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--page-accent) 16%, transparent),
                transparent 58%
            ),
            var(--page-surface-bg);
    }

    .overview-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        bottom: 0;
        width: 3px;
        background: linear-gradient(180deg, var(--page-decorator-start), var(--page-decorator-end));
        opacity: 0.78;
    }

    .overview-label {
        display: block;
        margin-bottom: 0.45rem;
        color: var(--text-content-secondary);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        line-height: 1.2;
        text-transform: uppercase;
    }

    .overview-value {
        color: var(--text-content-primary);
        font-size: 0.9375rem;
        line-height: 1.75;
        margin: 0;
        text-wrap: pretty;
    }

    .overview-project-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 0;
        min-width: 0;
    }

    .overview-project-link {
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        min-height: 1.75rem;
        padding: 0.375rem 0.625rem;
        color: var(--text-content-primary);
        background: color-mix(in oklch, var(--page-surface-bg) 78%, white);
        border: 1px solid color-mix(in oklch, var(--page-surface-border) 72%, transparent);
        border-radius: 0.375rem;
        font-size: 0.8125rem;
        font-weight: 700;
        line-height: 1.25;
        text-decoration: none;
        transition:
            border-color 0.2s ease,
            background 0.2s ease,
            color 0.2s ease;
    }

    .overview-project-link:hover {
        color: var(--foreground);
        background: var(--page-surface-bg-hover);
        border-color: var(--page-surface-border-hover);
    }

    .overview-project-name {
        min-width: 0;
        overflow-wrap: anywhere;
    }

    /* ===== 技术栈 ===== */
    .tech-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.875rem;
        margin-top: 1.25rem;
    }

    .tech-card {
        position: relative;
        overflow: hidden;
        min-width: 0;
        padding: 1rem;
        background:
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--tech-accent) 10%, transparent),
                transparent 54%
            ),
            var(--page-surface-bg);
        border: 1px solid var(--page-surface-border);
        border-radius: 0.5rem;
        box-shadow: 0 14px 30px var(--page-surface-shadow);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .tech-card--featured {
        background:
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--tech-accent) 18%, transparent),
                transparent 62%
            ),
            var(--page-surface-bg);
        border-color: color-mix(in oklch, var(--tech-accent) 42%, var(--page-surface-border));
    }

    .tech-card::before {
        content: '';
        position: absolute;
        top: 0;
        right: 0;
        left: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--tech-accent), transparent);
        opacity: 0.88;
    }

    .tech-card-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .tech-card-marker {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.75rem;
        height: 1.625rem;
        color: color-mix(in oklch, var(--tech-accent) 86%, white);
        background: color-mix(in oklch, var(--tech-accent) 18%, transparent);
        border: 1px solid color-mix(in oklch, var(--tech-accent) 36%, transparent);
        border-radius: 0.375rem;
        font-size: 0.625rem;
        font-weight: 800;
        line-height: 1;
        letter-spacing: 0;
        flex-shrink: 0;
    }

    .tech-card-title {
        margin: 0;
        color: var(--foreground);
        font-size: 0.9375rem;
        font-weight: 700;
        line-height: 1.3;
        letter-spacing: 0;
        min-width: 0;
    }

    .tech-badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4375rem;
        align-items: center;
    }

    .tech-badge {
        --tech-badge-bg: color-mix(in oklch, var(--page-surface-bg) 86%, white);
        --tech-badge-border: color-mix(in oklch, var(--page-surface-border) 78%, transparent);
        --tech-badge-text: color-mix(in oklch, var(--text-content-primary) 88%, black);
        --tech-badge-icon-color: var(--tech-color);
        --tech-badge-icon-bg: transparent;
        --tech-badge-fallback-bg: color-mix(in oklch, var(--tech-color) 78%, white);
        --tech-badge-fallback-text: oklch(0.985 0.006 250);
        display: inline-flex;
        align-items: center;
        gap: 0.3125rem;
        min-width: 0;
        height: 1.625rem;
        padding: 0 0.5625rem;
        color: var(--tech-badge-text);
        background: var(--tech-badge-bg);
        border: 1px solid var(--tech-badge-border);
        border-radius: 0.25rem;
        box-shadow:
            0 1px 0 oklch(1 0 0 / 0.46) inset,
            0 8px 18px oklch(0.36 0.035 250 / 0.08);
        font-size: 0.6875rem;
        font-weight: 700;
        line-height: 1;
        white-space: nowrap;
    }

    .tech-badge--muted {
        --tech-badge-bg: color-mix(in oklch, var(--page-surface-bg) 78%, white);
        --tech-badge-border: color-mix(in oklch, var(--page-surface-border) 58%, transparent);
        --tech-badge-text: var(--text-content-secondary);
        --tech-badge-icon-color: var(--tech-color);
        opacity: 0.94;
    }

    .tech-badge--light-logo {
        --tech-badge-icon-bg: oklch(0.2 0.026 260);
        --tech-badge-fallback-bg: oklch(0.2 0.026 260);
        --tech-badge-fallback-text: oklch(0.98 0.006 250);
    }

    .tech-badge-icon {
        width: 1rem;
        height: 1rem;
        padding: 0.125rem;
        color: var(--tech-badge-icon-color);
        background: var(--tech-badge-icon-bg);
        border-radius: 0.1875rem;
        flex-shrink: 0;
    }

    .tech-badge-fallback {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 0.875rem;
        height: 0.875rem;
        color: var(--tech-badge-fallback-text);
        background: var(--tech-badge-fallback-bg);
        border-radius: 0.1875rem;
        font-size: 0.5625rem;
        font-weight: 900;
        line-height: 1;
    }

    /* ===== 兴趣爱好 - 新设计 ===== */
    .hobbies-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        min-width: 0;
    }

    @media (min-width: 768px) {
        .overview-grid {
            grid-template-columns: 1.2fr 1fr;
        }

        .overview-card-primary {
            grid-row: span 2;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .tech-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    /* 爱好卡片 */
    .hobby-card {
        --hobby-accent-primary: var(--page-accent);
        --hobby-accent-secondary: var(--page-decorator-end);
        background:
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--hobby-accent-primary) 12%, transparent),
                transparent 48%
            ),
            var(--page-surface-bg);
        border: 1px solid var(--page-surface-border);
        border-radius: 0.5rem;
        padding: 1.125rem;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        min-width: 0;
        box-shadow: 0 16px 36px var(--page-surface-shadow);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    .hobby-card:hover {
        background:
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--hobby-accent-primary) 16%, transparent),
                transparent 54%
            ),
            var(--page-surface-bg-hover);
        border-color: var(--page-surface-border-hover);
        box-shadow: 0 22px 48px var(--page-surface-shadow-hover);
        transform: translateY(-1px);
    }

    .hobby-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        border-radius: 0.5rem 0.5rem 0 0;
        background: linear-gradient(
            90deg,
            var(--hobby-accent-primary),
            var(--hobby-accent-secondary)
        );
    }

    .hobby-card-gaming {
        --hobby-accent-primary: #66c0f4;
        --hobby-accent-secondary: #a78bfa;
        background:
            radial-gradient(
                circle at 0 0,
                color-mix(in oklch, var(--hobby-accent-secondary) 18%, transparent),
                transparent 30%
            ),
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--hobby-accent-primary) 12%, transparent),
                transparent 58%
            ),
            var(--page-surface-bg);
        border-color: color-mix(
            in oklch,
            var(--hobby-accent-primary) 24%,
            var(--page-surface-border)
        );
    }

    .hobby-card-gaming:hover {
        background:
            radial-gradient(
                circle at 0 0,
                color-mix(in oklch, var(--hobby-accent-secondary) 18%, transparent),
                transparent 30%
            ),
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--hobby-accent-primary) 12%, transparent),
                transparent 58%
            ),
            var(--page-surface-bg);
        border-color: color-mix(
            in oklch,
            var(--hobby-accent-primary) 24%,
            var(--page-surface-border)
        );
        box-shadow: 0 16px 36px var(--page-surface-shadow);
        transform: none;
    }

    .hobby-card-music {
        --hobby-accent-primary: #f472b6;
        --hobby-accent-secondary: #a855f7;
    }

    /* 卡片头部 */
    .hobby-card-header {
        display: flex;
        align-items: flex-start;
        gap: 0.875rem;
        margin-bottom: 0.875rem;
        padding-bottom: 0.875rem;
        border-bottom: 1px solid color-mix(in oklch, var(--page-surface-border) 78%, transparent);
    }

    .hobby-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        font-size: 1.125rem;
        background: color-mix(in oklch, var(--hobby-accent-primary) 16%, transparent);
        border: 1px solid color-mix(in oklch, var(--hobby-accent-primary) 34%, transparent);
        border-radius: 0.5rem;
        flex-shrink: 0;
    }

    .hobby-heading {
        min-width: 0;
    }

    .hobby-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--foreground);
        margin: 0;
    }

    .hobby-description {
        margin: 0.35rem 0 0;
        color: var(--text-content-primary);
        font-size: 0.875rem;
        line-height: 1.7;
        overflow-wrap: anywhere;
        text-wrap: pretty;
    }

    .hobby-card-gaming .hobby-card-header {
        margin-bottom: 1rem;
        padding: 0.125rem 0 1rem;
        border-bottom-color: color-mix(
            in oklch,
            var(--hobby-accent-primary) 20%,
            var(--page-surface-border)
        );
    }

    .hobby-card-gaming .hobby-icon {
        color: color-mix(in oklch, var(--hobby-accent-primary) 86%, white);
        background:
            linear-gradient(
                135deg,
                color-mix(in oklch, var(--hobby-accent-primary) 18%, transparent),
                color-mix(in oklch, var(--hobby-accent-secondary) 12%, transparent)
            ),
            color-mix(in oklch, var(--page-surface-bg) 78%, transparent);
        border-color: color-mix(in oklch, var(--hobby-accent-primary) 38%, transparent);
        box-shadow: 0 10px 24px color-mix(in oklch, var(--hobby-accent-primary) 12%, transparent);
    }

    .hobby-card-gaming .hobby-title {
        font-size: 1.25rem;
        letter-spacing: 0;
    }

    .hobby-card-gaming .hobby-description {
        max-width: 62rem;
        color: color-mix(in oklch, var(--text-content-primary) 88%, var(--foreground));
    }

    /* 详情区块 */
    .hobby-details {
        display: flex;
        flex-direction: column;
    }

    .hobby-detail-row {
        display: grid;
        grid-template-columns: minmax(6.5rem, 0.32fr) 1fr;
        gap: 1rem;
        align-items: start;
        min-width: 0;
        padding: 0.875rem 0;
        border-bottom: 1px solid color-mix(in oklch, var(--page-surface-border) 70%, transparent);
    }

    .hobby-detail-row:first-child {
        padding-top: 0;
    }

    .hobby-detail-row:last-child {
        padding-bottom: 0;
        border-bottom: 0;
    }

    .hobby-detail-row--highlight {
        border-left: 3px solid color-mix(in oklch, var(--hobby-accent-primary) 72%, transparent);
        padding-left: 0.75rem;
    }

    .gaming-setup-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        margin-top: 0.875rem;
    }

    .gaming-setup-panel,
    .gaming-setup-panel:first-child,
    .gaming-setup-panel:last-child {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.75rem;
        align-content: start;
        min-width: 0;
        padding: 0.875rem;
        background:
            linear-gradient(
                145deg,
                color-mix(in oklch, var(--hobby-accent-primary) 8%, transparent),
                transparent 66%
            ),
            color-mix(in oklch, var(--page-surface-bg) 76%, black);
        border: 1px solid
            color-mix(in oklch, var(--hobby-accent-primary) 18%, var(--page-surface-border));
        border-radius: 0.5rem;
