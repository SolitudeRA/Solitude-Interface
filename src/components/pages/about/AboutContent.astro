    },
    ja: {
        atAGlance: 'ひと目でわかる',
        profile: '概要',
        intro: '理系オタク。食べるのが好きで、音楽を聴くのもゲームをするのも好き。',
        spokenLanguages: '言語',
        languages: '中国語（母語） / 日本語（JLPT N1） / 英語（CEFR B2）',
        focus: '個人プロジェクト',
