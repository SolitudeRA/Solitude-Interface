---
/**
 * AboutContent - 关于页面的内容组件
 * 支持多语言
 */
import type { Locale } from '@lib/i18n';

interface Props {
    locale?: Locale;
}

const { locale = 'zh' } = Astro.props;

// 多语言文本
const i18n = {
    zh: {
        atAGlance: 'At a Glance',
