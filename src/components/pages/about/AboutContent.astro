        gaming: 'ゲーム',
        gamingDesc:
            'FPS/TPS、ARPG、CRPG、MOBA、音ゲー、カード系…ジャンルは何でも遊びます。得意なのはFPSで、いちばん好きなのはCounter-Strike',
        hardwareSpec: 'メインPCスペック',
        hardwareDesc: 'AMD 5900X | 32GB RAM | ASUS Strix RTX 4080 | ASUS B550-A Gaming',
        peripheral: '周辺機器',
