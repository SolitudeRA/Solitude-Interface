---
import { initializeSiteData } from '@api/ghost/settings';
import { listAllPosts } from '@api/ghost/posts';
import type { Post } from '@api/ghost/types';
import BaseLayout from '@layouts/base/BaseLayout.astro';
import SiteNavbar from '@components/layout/navbar/SiteNavbar.astro';
import SiteDock from '@components/layout/dock/SiteDock.astro';
import PostContent from '@components/posts/detail/PostContent.astro';
import { DEFAULT_LOCALE, extractLocaleFromTags } from '@lib/i18n';

interface Props {
    post: Post;
    redirectTo: string | null;
}

const { siteTitle, siteDescription, logoUrl, coverImageUrl } = await initializeSiteData();

export async function getStaticPaths() {
    const posts = await listAllPosts();

    return Array.from(posts, (post) => {
        const legacyPath = `/posts/${post.id}`;
        const frontendPath = post.url.pathname;

        return {
            params: {
                post: post.id,
            },
            props: {
                post,
                redirectTo: frontendPath !== legacyPath ? frontendPath : null,
            },
        };
    });
}

const { post, redirectTo } = Astro.props;

const locale = extractLocaleFromTags(post.tags) ?? DEFAULT_LOCALE;
---

{
    redirectTo ? (
        <html lang="en">
            <head>
                <meta charset="UTF-8" />
                <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                <meta http-equiv="refresh" content={`0;url=${redirectTo}`} />
                <meta name="robots" content="noindex" />
                <link rel="canonical" href={redirectTo} />
                <title>Redirecting...</title>
                <script is:inline define:vars={{ redirectTo }}>
                    window.location.replace(redirectTo);
                </script>
            </head>
            <body>
                <p>
                    Redirecting to <a href={redirectTo}>{redirectTo}</a>...
                </p>
            </body>
        </html>
    ) : (
        <BaseLayout
            siteTitle={`${siteTitle} - ${post.title}`}
            coverImageUrl={coverImageUrl}
            locale={locale}
        >
            <SiteNavbar
                logoUrl={logoUrl}
                siteTitle={siteTitle}
                siteSubTitle={siteDescription}
                homeUrl={`/${locale}`}
                isFixed={true}
            />
            <PostContent
                title={post.title}
                feature_image={post.feature_image}
                primary_tag={post.primary_tag}
                tags={post.tags}
                published_at={post.published_at}
                html={post.html}
            />
            <SiteDock isFixed={true} layout="home" lang={locale} />
        </BaseLayout>
    )
}
